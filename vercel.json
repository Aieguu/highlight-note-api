{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/sync",
      "dest": "/api/sync.ts"
    },
    {
      "src": "/api/notes/(.*)",
      "dest": "/api/notes/[id].ts?id=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 20 * * *"
    }
  ]
}
