# GitHub Fine-grained Personal Access Token
# 需要 Contents: Read and write 权限
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub 仓库 (格式: owner/repo)
GITHUB_REPO=Aieguu/blog

# GitHub 分支 (默认: main)
GITHUB_BRANCH=main

# Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# 同步密钥（用于手动调用同步接口）
SYNC_SECRET=your-secret-key

# Vercel Cron 密钥（在 Vercel 控制台自动生成）
CRON_SECRET=xxxxxxxxxxxxxxxx

# 前端写入令牌（建议 openssl rand -hex 32 生成）
WRITE_TOKEN=your-write-token

# 允许调用 API 的站点来源，逗号分隔（留空不限制）
ALLOWED_ORIGINS=https://blog.example.com

# 可查找的文章 section，逗号分隔（默认 posts）
CONTENT_SECTIONS=posts

# 笔记落盘目录（默认 content/notes）
NOTES_ROOT=content/notes
